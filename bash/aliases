. ~/.zsh/aliases

# changing directory to code project
function p { cd ~/work/code/projects/$1; }

# alternative to "rails" command to use templates
function railsapp {
  template=$1
  appname=$2
  shift 2
  # rails $appname -m http://github.com/ryanb/rails-templates/raw/master/$template.rb $@
  rails new $appname -T -m http://github.com/forest/rails3_template/raw/master/main.rb $@
}

# misc
alias reload='. ~/.bash_profile'
