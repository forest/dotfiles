<%
  print("Your Name: ")
  STDOUT.flush
  name = STDIN.gets.chomp

  print("Your Email: ")
  STDOUT.flush
  email = STDIN.gets.chomp
%>

# Set your git user info
export GIT_AUTHOR_NAME='<%= name %>'
export GIT_AUTHOR_EMAIL='<%= email %>'
export GIT_COMMITTER_NAME='<%= name %>'
export GIT_COMMITTER_EMAIL='<%= email %>'

# Optionally, set your GitHub credentials
export GITHUB_USER='<%= print("GitHub Username: "); STDOUT.flush; STDIN.gets.chomp %>'
export GITHUB_TOKEN='<%= print("GitHub API Token: "); STDOUT.flush; STDIN.gets.chomp %>'
# Add Keychain entry for your GitHub password
#  $ security add-generic-password -a YOUR_LOCAL_OSX_USER -s github.password -w YOUR_GITHUB_PASSWORD
# Export password for gist cli
export GITHUB_PASSWORD=$(security 2>&1 >/dev/null find-generic-password -gs github.password | sed 's/password: "\(.*\)"/\1/')

