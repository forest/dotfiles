      }
    },
    "portfolio-growth-planner": {
      "source": {
        "source": "github",
        "repo": "caylent/portfolio-growth-planner"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "preferredNotifChannel": "terminal_bell",
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754076959040
  },
  "mcpServers": {
    "qmd": {
      "command": "qmd",
      "args": ["mcp"]
    }
  }
}
