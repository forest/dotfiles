      },
      "autoUpdate": true
    },
    "mem0-plugins": {
      "source": {
        "source": "github",
        "repo": "mem0ai/mem0"
      },
      "autoUpdate": true
    },
    "oliver-kriska": {
      "source": {
        "source": "directory",
        "path": "/Users/forest/code/claude-elixir-phoenix"
      },
      "autoUpdate": true
    },
    "qmd": {
      "source": {
        "source": "github",
